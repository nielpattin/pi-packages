{
   "name": "@nielpattin/pi-station",
   "version": "0.5.6",
   "description": "Station bar status extension for pi coding agent",
   "keywords": [
      "coding-agent",
      "extension",
      "pi",
      "pi-package",
      "station-bar",
      "status-bar"
   ],
   "license": "MIT",
   "author": "Niel Pattin",
   "main": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "files": [
      "dist",
      "*.md",
      "*.json",
      "!progress.md",
      "!tsconfig*.json",
      "!dist/tsconfig.build.tsbuildinfo"
   ],
   "repository": {
      "type": "git",
      "url": "git+https://github.com/nielpattin/pi-packages.git",
      "directory": "pi-station"
   },
   "homepage": "https://github.com/nielpattin/pi-packages/tree/main/pi-station#readme",
   "bugs": {
      "url": "https://github.com/nielpattin/pi-packages/issues"
   },
   "publishConfig": {
      "access": "public"
   },
   "type": "module",
   "scripts": {
      "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('tsconfig.build.tsbuildinfo',{force:true});\"",
      "build": "npm run clean && tsc -p tsconfig.build.json",
      "prepack": "node -e \"const fs=require('node:fs');if(!fs.existsSync('dist')){console.error('Error: dist/ missing. Run npm run build first.');process.exit(1);}\"",
      "test": "vitest run"
   },
   "devDependencies": {
      "@earendil-works/pi-ai": "*",
      "@earendil-works/pi-coding-agent": "*",
      "@earendil-works/pi-tui": "*",
      "@types/node": "^25.8.0",
      "typescript": "^6.0.3",
      "vitest": "^4.1.6"
   },
   "peerDependencies": {
      "@earendil-works/pi-ai": "*",
      "@earendil-works/pi-coding-agent": "*",
      "@earendil-works/pi-tui": "*"
   },
   "pi": {
      "extensions": [
         "./dist/index.js"
      ]
   }
}
