{
   "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
   "vcs": {
      "enabled": true,
      "clientKind": "git",
      "useIgnoreFile": true
   },
   "files": {
      "ignoreUnknown": true,
      "includes": ["**", "!**/node_modules", "!dist", "!build", "!coverage"]
   },
   "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 3,
      "lineWidth": 120
   },
   "assist": {
      "actions": {
         "source": {
            "organizeImports": "off"
         }
      }
   },
   "linter": {
      "enabled": true,
      "domains": {
         "project": "all"
      },
      "rules": {
         "recommended": true,
         "suspicious": {
            "noControlCharactersInRegex": "off",
            "useIterableCallbackReturn": "off",
            "noAssignInExpressions": "off",
            "noImplicitAnyLet": "off",
            "noExplicitAny": "off",
            "noDeprecatedImports": "off"
         },
         "style": {
            "noNestedTernary": "off",
            "noNonNullAssertion": "off",
            "useNodejsImportProtocol": "off",
            "useImportType": "off"
         },
         "correctness": {
            "noUnusedImports": "off",
            "noUnusedVariables": "off",
            "noUnusedFunctionParameters": "off",
            "noUnresolvedImports": "off",
            "useImportExtensions": "off",
            "noUndeclaredDependencies": "off",
            "useJsonImportAttributes": "off"
         },
         "complexity": {
            "useOptionalChain": "off"
         },
         "nursery": {
            "noBaseToString": "off"
         }
      }
   },
   "javascript": {
      "formatter": {
         "trailingCommas": "none",
         "semicolons": "always"
      }
   },
   "overrides": [
      {
         "includes": ["**/tests/**", "**/*.test.ts"],
         "linter": {
            "enabled": false
         }
      }
   ]
}
