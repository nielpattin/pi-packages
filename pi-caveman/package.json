{
   "name": "@nielpattin/pi-caveman",
   "version": "1.0.2",
   "description": "Caveman mode for pi — terse output, ~75% fewer tokens, full technical accuracy",
   "keywords": [
      "pi-package"
   ],
   "license": "MIT",
   "main": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "files": [
      "dist",
      "README.md",
      "skills"
   ],
   "repository": {
      "type": "git",
      "url": "git+https://github.com/nielpattin/pi-packages.git",
      "directory": "pi-caveman"
   },
   "homepage": "https://github.com/nielpattin/pi-packages/tree/main/pi-caveman#readme",
   "bugs": {
      "url": "https://github.com/nielpattin/pi-packages/issues"
   },
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('tsconfig.build.tsbuildinfo',{force:true});\"",
      "build": "npm run clean && tsc -p tsconfig.build.json",
      "prepack": "node -e \"const fs=require('node:fs');if(!fs.existsSync('dist')){console.error('Error: dist/ missing. Run npm run build first.');process.exit(1);}\""
   },
   "peerDependencies": {
      "@earendil-works/pi-coding-agent": "*"
   },
   "devDependencies": {
      "@earendil-works/pi-coding-agent": "^0.74.1",
      "typescript": "^6.0.3"
   },
   "pi": {
      "extensions": [
         "./dist/index.js"
      ],
      "skills": [
         "./skills/caveman/SKILL.md",
         "./skills/caveman-review/SKILL.md",
         "./skills/compress/SKILL.md",
         "./skills/caveman-commit/SKILL.md"
      ]
   }
}
