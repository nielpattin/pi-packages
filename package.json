{
   "private": true,
   "workspaces": [
      "packages/*"
   ],
   "type": "module",
   "scripts": {
      "test": "vitest run",
      "coverage": "vitest run --coverage",
      "lint": "oxlint --fix .",
      "fmt": "oxfmt --write .",
      "check": "oxlint . && oxfmt --check . && tsc --noEmit -p tsconfig.json",
      "typecheck": "tsc --noEmit -p tsconfig.json",
      "prepare": "husky",
      "changeset": "changeset",
      "version-packages": "changeset version && pnpm changelog:sync",
      "release": "changeset publish",
      "changelog:sync": "node scripts/sync-monorepo-changelog.mjs",
      "changeset:check": "node scripts/require-changeset.mjs"
   },
   "devDependencies": {
      "@changesets/changelog-git": "^0.2.1",
      "@changesets/cli": "^2.31.0",
      "@earendil-works/pi-ai": "^0.78.0",
      "@earendil-works/pi-coding-agent": "^0.78.0",
      "@earendil-works/pi-tui": "^0.78.0",
      "@sinclair/typebox": "^0.34.49",
      "@types/node": "^25.7.0",
      "@vitest/coverage-v8": "^4.1.6",
      "husky": "^9.1.7",
      "lint-staged": "^17.0.5",
      "oxfmt": "^0.51.0",
      "oxlint": "^1.66.0",
      "oxlint-tsgolint": "^0.23.0",
      "typescript": "^6.0.3",
      "vitest": "^4.1.6"
   },
   "lint-staged": {
      "**/!(*.test).{js,jsx,mjs,cjs,ts,tsx}": [
         "oxlint",
         "oxfmt --check"
      ],
      "**/*.test.{js,jsx,mjs,cjs,ts,tsx}": "oxfmt --check",
      "*.{json,jsonc,md,yaml,yml}": "oxfmt --check"
   },
   "engines": {
      "node": ">=24"
   }
}
