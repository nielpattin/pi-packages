{
   "private": true,
   "workspaces": [
      "packages/*"
   ],
   "type": "module",
   "scripts": {
      "test": "vitest run",
      "coverage": "vitest run --coverage",
      "check": "biome check .",
      "check:fix": "biome check --write .",
      "typecheck": "tsc --noEmit -p tsconfig.json",
      "prepare": "husky",
      "changeset": "changeset",
      "version-packages": "changeset version && pnpm changelog:sync",
      "release": "changeset publish",
      "changelog:sync": "node scripts/sync-monorepo-changelog.mjs",
      "changeset:check": "node scripts/require-changeset.mjs"
   },
   "devDependencies": {
      "@biomejs/biome": "^2.4.16",
      "@changesets/changelog-git": "^0.2.1",
      "@changesets/cli": "^2.31.0",
      "@earendil-works/pi-ai": "^0.78.0",
      "@earendil-works/pi-coding-agent": "^0.78.0",
      "@earendil-works/pi-tui": "^0.78.0",
      "@sinclair/typebox": "^0.34.49",
      "@types/node": "^25.7.0",
      "@types/xxhashjs": "^0.2.4",
      "@vitest/coverage-v8": "^4.1.6",
      "husky": "^9.1.7",
      "lint-staged": "^17.0.5",
      "typescript": "^6.0.3",
      "vitest": "^4.1.6"
   },
   "lint-staged": {
      "**/*.{js,jsx,mjs,cjs,ts,tsx,json,jsonc}": [
         "biome check --write"
      ]
   },
   "engines": {
      "node": ">=24"
   }
}
