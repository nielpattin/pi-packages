{
   "name": "@nielpattin/pi-station",
   "version": "0.8.0",
   "description": "Station bar status extension for pi coding agent",
   "keywords": [
      "coding-agent",
      "extension",
      "pi",
      "pi-package",
      "station-bar",
      "status-bar"
   ],
   "homepage": "https://github.com/nielpattin/pi-packages/tree/main/packages/pi-station#readme",
   "bugs": {
      "url": "https://github.com/nielpattin/pi-packages/issues"
   },
   "license": "MIT",
   "author": "Niel Pattin",
   "repository": {
      "type": "git",
      "url": "git+https://github.com/nielpattin/pi-packages.git",
      "directory": "packages/pi-station"
   },
   "files": [
      "dist",
      ".pi/agents",
      "theme.example.json",
      "README.md",
      "CHANGELOG.md",
      "LICENSE"
   ],
   "type": "module",
   "main": "./dist/index.js",
   "exports": {
      ".": {
         "default": "./dist/index.js"
      },
      "./features/hashline/edit-tool": {
         "default": "./dist/features/hashline/edit-tool.js"
      },
      "./package.json": "./package.json"
   },
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "build": "node scripts/build.mjs",
      "test": "vitest run"
   },
   "dependencies": {
      "diff": "^9.0.0",
      "file-type": "^22.0.1",
      "xxhashjs": "^0.2.2"
   },
   "devDependencies": {
      "esbuild": "^0.28.1"
   },
   "peerDependencies": {
      "@earendil-works/pi-ai": "*",
      "@earendil-works/pi-coding-agent": "*",
      "@earendil-works/pi-tui": "*"
   },
   "engines": {
      "node": ">=24"
   },
   "pi": {
      "extensions": [
         "./dist/index.js"
      ]
   }
}
