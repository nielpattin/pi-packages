{
   "name": "@nielpattin/pi-caveman",
   "version": "1.0.4",
   "description": "Caveman mode for pi — terse output, ~75% fewer tokens, full technical accuracy",
   "keywords": [
      "pi-package"
   ],
   "homepage": "https://github.com/nielpattin/pi-packages/tree/main/packages/pi-caveman#readme",
   "bugs": {
      "url": "https://github.com/nielpattin/pi-packages/issues"
   },
   "license": "MIT",
   "repository": {
      "type": "git",
      "url": "git+https://github.com/nielpattin/pi-packages.git",
      "directory": "packages/pi-caveman"
   },
   "files": [
      "index.ts",
      "extensions",
      "skills",
      "README.md",
      "CHANGELOG.md"
   ],
   "type": "module",
   "main": "./index.ts",
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "test": "vitest run"
   },
   "peerDependencies": {
      "@earendil-works/pi-coding-agent": "*"
   },
   "engines": {
      "node": ">=24"
   },
   "pi": {
      "extensions": [
         "./index.ts"
      ],
      "skills": [
         "./skills/caveman/SKILL.md",
         "./skills/caveman-review/SKILL.md",
         "./skills/compress/SKILL.md",
         "./skills/caveman-commit/SKILL.md"
      ]
   }
}
