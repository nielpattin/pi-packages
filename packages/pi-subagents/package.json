{
   "name": "@nielpattin/pi-subagents",
   "version": "0.2.0",
   "description": "Pi extension for spawning and managing autonomous subagents.",
   "keywords": [
      "agent",
      "autonomous",
      "pi",
      "pi-extension",
      "pi-package",
      "subagent"
   ],
   "homepage": "https://github.com/nielpattin/pi-packages/tree/main/packages/pi-subagents#readme",
   "bugs": {
      "url": "https://github.com/nielpattin/pi-packages/issues"
   },
   "license": "MIT",
   "author": "Niel Pattin",
   "repository": {
      "type": "git",
      "url": "git+https://github.com/nielpattin/pi-packages.git",
      "directory": "packages/pi-subagents"
   },
   "files": [
      "dist",
      ".pi/agents",
      "README.md",
      "CHANGELOG.md",
      "LICENSE"
   ],
   "type": "module",
   "main": "./dist/index.js",
   "types": "./dist/src/index.d.ts",
   "imports": {
      "#src/*": "./dist/src/*.js",
      "#test/helpers/*": "./test/helpers/*.ts"
   },
   "exports": {
      ".": {
         "types": "./dist/src/service/service.d.ts",
         "default": "./dist/src/service/service.js"
      },
      "./package.json": "./package.json"
   },
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "build": "node scripts/build.mjs",
      "test": "vitest run --config vitest.config.ts",
      "check": "pnpm test && tsc --noEmit -p tsconfig.json"
   },
   "devDependencies": {
      "esbuild": "^0.28.1"
   },
   "peerDependencies": {
      "@earendil-works/pi-ai": "*",
      "@earendil-works/pi-coding-agent": "*",
      "@earendil-works/pi-tui": "*",
      "typebox": "*"
   },
   "engines": {
      "node": ">=24"
   },
   "pi": {
      "extensions": [
         "./dist/index.js"
      ]
   }
}
