{
   "name": "@nielpattin/pi-magic-context",
   "version": "0.1.0",
   "description": "Pi extension for Magic Context, adapted for Niel's Pi packages workspace",
   "keywords": [
      "context",
      "extension",
      "magic-context",
      "memory",
      "pi",
      "pi-coding-agent"
   ],
   "license": "MIT",
   "type": "module",
   "main": "./src/index.ts",
   "imports": {
      "#core/*": "./core/*.ts"
   },
   "scripts": {
      "typecheck": "tsc --noEmit",
      "doctor": "node scripts/doctor.mjs",
      "smoke": "node scripts/smoke.mjs",
      "test": "pnpm smoke",
      "check": "pnpm typecheck && pnpm doctor"
   },
   "dependencies": {
      "@huggingface/transformers": "^4.1.0",
      "ai-tokenizer": "^1.0.6",
      "better-sqlite3": "^12.9.0",
      "comment-json": "^4.2.5",
      "typebox": "^1.1.24",
      "zod": "^4.1.8"
   },
   "devDependencies": {
      "@types/better-sqlite3": "^7.6.13"
   },
   "peerDependencies": {
      "@earendil-works/pi-coding-agent": "^0.78.0",
      "@earendil-works/pi-tui": "^0.78.0"
   },
   "pi": {
      "extensions": [
         "./src/index.ts"
      ]
   }
}
