{
   "name": "@nielpattin/pi-permission-system",
   "version": "0.2.2",
   "description": "Permission enforcement extension for the Pi coding agent.",
   "keywords": [
      "access-control",
      "authorization",
      "coding-agent",
      "permissions",
      "pi",
      "pi-coding-agent",
      "pi-extension",
      "pi-package",
      "policy",
      "security"
   ],
   "homepage": "https://github.com/nielpattin/pi-packages/tree/main/packages/pi-permission-system#readme",
   "bugs": {
      "url": "https://github.com/nielpattin/pi-packages/issues"
   },
   "license": "MIT",
   "author": "Niel Pattin",
   "repository": {
      "type": "git",
      "url": "git+https://github.com/nielpattin/pi-packages.git",
      "directory": "packages/pi-permission-system"
   },
   "files": [
      "src",
      "config/config.example.json",
      "schemas/permissions.schema.json",
      "docs/configuration.md",
      "docs/cross-extension-api.md",
      "docs/guides/permission-frontmatter-for-subagent-extensions.md",
      "docs/migration/legacy-to-flat.md",
      "docs/opencode-compatibility.md",
      "docs/session-approvals.md",
      "docs/subagent-integration.md",
      "docs/troubleshooting.md",
      "README.md",
      "CHANGELOG.md",
      "LICENSE"
   ],
   "type": "module",
   "main": "./src/index.ts",
   "imports": {
      "#src/*": "./src/*",
      "#test/*": "./test/*"
   },
   "exports": {
      ".": "./src/service.ts"
   },
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "test": "vitest run --config vitest.config.ts",
      "check": "pnpm test && tsc --noEmit -p tsconfig.json"
   },
   "dependencies": {
      "tree-sitter-bash": "^0.25.1",
      "web-tree-sitter": "^0.26.8"
   },
   "peerDependencies": {
      "@earendil-works/pi-coding-agent": "*",
      "@earendil-works/pi-tui": "*"
   },
   "engines": {
      "node": ">=24"
   },
   "pi": {
      "extensions": [
         "./src/index.ts"
      ]
   }
}
