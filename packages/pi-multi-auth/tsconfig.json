{
   "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "lib": ["ES2023", "DOM"],
      "strict": true,
      "noEmit": true,
      "skipLibCheck": true,
      "resolveJsonModule": true,
      "types": ["node"]
   },
   "include": ["index.ts", "src/**/*.ts"],
   "exclude": ["node_modules", ".test-dist", "debug", "tests"]
}
